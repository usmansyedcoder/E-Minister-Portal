{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "api/health.js"
    },
    {
      "src": "/api/complaints",
      "dest": "api/complaints.js"
    },
    {
      "src": "/api/suggestions",
      "dest": "api/suggestions.js"
    },
    {
      "src": "/api/complaints/track/(.*)",
      "dest": "api/complaints-track-[id].js"
    },
    {
      "src": "/api/suggestions/track/(.*)",
      "dest": "api/suggestions-track-[id].js"
    },
    {
      "src": "/(.*)",
      "dest": "api/complaints.js"
    }
  ]
}